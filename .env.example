# Copy this file to .env and fill in your own Supabase project's values
# (Project Settings → API in the Supabase dashboard).
#
# Expo inlines any env var prefixed EXPO_PUBLIC_ into the client bundle at
# build time — that's expected for the anon key (it's meant to be public;
# RLS is what actually protects data, not keeping this key secret).
#
# Leave these unset to run the app in demo mode — see supabase/README.md.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
