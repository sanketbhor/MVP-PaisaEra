# Reuses the same Postgres project as the rest of the app (see ../.env) —
# this backend connects directly, bypassing Supabase's PostgREST/RLS layer
# entirely, since it does its own authorization at the application layer.
DATABASE_URL=postgresql://postgres.szrxpzxlefrlkbiasvia:<url-encoded-password>@aws-1-ap-south-1.pooler.supabase.com:5432/postgres

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Never reuse the dev default below outside local dev.
JWT_SECRET=dev-insecure-secret-change-me

# console = prints the OTP to this process's stdout, for local dev.
# msg91 / twilio = real delivery, both currently stubbed pending credentials.
SMS_PROVIDER=console
MSG91_API_KEY=
MSG91_SENDER_ID=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Same pepper concept as public.users.phone_hash in supabase/migrations —
# keep these two in sync if you ever want the two hashes to be comparable.
PHONE_HASH_PEPPER=dev-insecure-pepper-change-me

# Chat phrasing (see ai_service.py). Get a free key at aistudio.google.com.
AI_DEFAULT_MODEL=gemini/gemini-2.5-flash
GEMINI_API_KEY=
AI_MAX_RESPONSE_TOKENS=1000
